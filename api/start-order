import { createClient } from "@supabase/supabase-js";
import nodemailer from "nodemailer";

const supabase = createClient(
  process.env.SUPABASE_URL,
  process.env.SUPABASE_SERVICE_ROLE_KEY
);

export default async function handler(req, res) {
  if (req.method !== "POST") {
    return res.status(405).json({ error: "Method not allowed" });
  }

  try {
    const data = req.body;

    // 🔹 VALIDACE
    if (!data.schoolName || !data.ico || !data.email) {
      return res.status(400).json({
        error: "Chybí povinné údaje",
      });
    }

    // 🔹 ULOŽENÍ DO DB
    const { error: dbError } = await supabase.from("orders_start").insert([
      {
        school_name: data.schoolName,
        ico: data.ico,
        street: data.street,
        city: data.city,
        zip: data.zip,
        contact_name: data.contactName,
        role: data.role,
        email: data.email,
        phone: data.phone,
        note: data.note,
      },
    ]);

    if (dbError) {
      console.error("DB ERROR:", dbError);
      throw new Error("Chyba uložení do DB");
    }

    // 🔹 SMTP (STEJNÉ jako poptavka.js)
    const transporter = nodemailer.createTransport({
      host: process.env.SMTP_HOST,
      port: Number(process.env.SMTP_PORT),
      secure: Number(process.env.SMTP_PORT) === 465,
      auth: {
        user: process.env.SMTP_USER,
        pass: process.env.SMTP_PASS,
      },
    });

    // 🔹 EMAIL INTERNÍ (vám)
    await transporter.sendMail({
      from: process.env.MAIL_FROM,
      to: process.env.MAIL_TO,
      subject: "🟢 NOVÁ OBJEDNÁVKA – ARCHIMEDES START",
      html: `
        <h2>Nová objednávka START</h2>

        <p><strong>Škola:</strong> ${data.schoolName}</p>
        <p><strong>IČO:</strong> ${data.ico}</p>

        <hr/>

        <p><strong>Kontakt:</strong> ${data.contactName}</p>
        <p><strong>Email:</strong> ${data.email}</p>
        <p><strong>Telefon:</strong> ${data.phone || "-"}</p>

        <hr/>

        <p><strong>Adresa:</strong><br/>
        ${data.street || ""}<br/>
        ${data.city || ""} ${data.zip || ""}
        </p>

        <p><strong>Poznámka:</strong><br/>
        ${data.note || "-"}
        </p>
      `,
    });

    // 🔹 EMAIL ZÁKAZNÍK
    await transporter.sendMail({
      from: process.env.MAIL_FROM,
      to: data.email,
      subject: "Potvrzení objednávky – ARCHIMEDES Live",
      html: `
        <h2>Děkujeme za objednávku</h2>

        <p>Vaše objednávka balíčku <strong>ARCHIMEDES START</strong> byla přijata.</p>

        <p><strong>Období:</strong> duben – červen 2026</p>
        <p><strong>Cena:</strong> 4 990 Kč bez DPH</p>

        <br/>

        <p>V nejbližší době vás budeme kontaktovat a zašleme podklady k aktivaci.</p>

        <br/>

        <p>S pozdravem,<br/>
        <strong>ARCHIMEDES Live</strong><br/>
        EduVision s.r.o.</p>
      `,
    });

    return res.status(200).json({ success: true });

  } catch (err) {
    console.error("SERVER ERROR:", err);

    return res.status(500).json({
      error: "Server error",
    });
  }
}
